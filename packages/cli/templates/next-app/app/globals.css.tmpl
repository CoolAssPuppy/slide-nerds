@import 'tailwindcss';

*,
*::before,
*::after {
  box-sizing: border-box;
}

html,
body {
  margin: 0;
  padding: 0;
  overflow: hidden;
  height: 100vh;
  width: 100vw;
  background: var(--color-background);
  color: var(--color-text);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* Slide engine */
[data-slide] {
  position: absolute;
  inset: 0;
  display: none;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

[data-slide].active {
  display: flex;
}

[data-slide] > * {
  min-height: 100%;
  width: 100%;
}

[data-notes] {
  display: none;
}

/* Step animation system */
[data-step] {
  visibility: hidden;
  opacity: 0;
}

[data-step].step-fade {
  transition:
    opacity 350ms cubic-bezier(0.4, 0, 0.2, 1),
    visibility 350ms cubic-bezier(0.4, 0, 0.2, 1);
}

[data-step].step-move-up {
  transform: translateY(24px);
  transition:
    opacity 400ms cubic-bezier(0.4, 0, 0.2, 1),
    transform 400ms cubic-bezier(0.4, 0, 0.2, 1),
    visibility 400ms cubic-bezier(0.4, 0, 0.2, 1);
}

[data-step].step-scale-in {
  transform: scale(0.92);
  transition:
    opacity 350ms cubic-bezier(0.16, 1, 0.3, 1),
    transform 350ms cubic-bezier(0.16, 1, 0.3, 1),
    visibility 350ms cubic-bezier(0.16, 1, 0.3, 1);
}

[data-step].step-move-left {
  transform: translateX(-30px);
  transition:
    opacity 400ms cubic-bezier(0.4, 0, 0.2, 1),
    transform 400ms cubic-bezier(0.4, 0, 0.2, 1),
    visibility 400ms cubic-bezier(0.4, 0, 0.2, 1);
}

/* Visible state applied by runtime */
[data-step].step-visible {
  visibility: visible !important;
  opacity: 1 !important;
  transform: translateY(0) translateX(0) scale(1) !important;
}

/* Emphasis entrance for big stats */
[data-step].step-emphasis.step-visible {
  animation: emphasis-land 500ms cubic-bezier(0.16, 1, 0.3, 1) 1;
}

@keyframes emphasis-land {
  0% { transform: scale(0.85); opacity: 0; }
  60% { transform: scale(1.03); }
  100% { transform: scale(1); opacity: 1; }
}
